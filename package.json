{
  "name": "@k9kbdev/r3f-projectiles",
  "version": "0.3.1",
  "description": "Composable, GPU-instanced projectile system for React Three Fiber. Zero-allocation render loop. 10,000+ simultaneous bullets at 120fps.",
  "license": "MIT",
  "author": "Kaleb Kougl",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kaleb-Kougl/r3f-projectiles"
  },
  "keywords": [
    "react",
    "three",
    "r3f",
    "react-three-fiber",
    "projectiles",
    "particles",
    "instanced-mesh",
    "webgl",
    "3d",
    "game-dev"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./patterns": {
      "import": {
        "types": "./dist/patterns.d.ts",
        "default": "./dist/patterns.js"
      },
      "require": {
        "types": "./dist/patterns.d.cts",
        "default": "./dist/patterns.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "postinstall.js"
  ],
  "scripts": {
    "postinstall": "node postinstall.js",
    "build": "tsup",
    "dev": "tsup --watch",
    "dev:stress": "vite examples/stress-test",
    "build:stress": "vite build examples/stress-test --base=/r3f-projectiles/",
    "test": "vitest run",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint src examples --ext .ts,.tsx",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@react-three/fiber": ">=8",
    "react": ">=18",
    "three": ">=0.150"
  },
  "devDependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": ">=8",
    "@react-three/test-renderer": "^9.1.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/three": "^0.170.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "leva": "^0.10.1",
    "react": ">=18",
    "react-dom": ">=18",
    "three": ">=0.150",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.2.0"
  }
}
